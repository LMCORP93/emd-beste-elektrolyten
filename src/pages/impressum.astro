---
import BaseLayout from '@/layouts/BaseLayout.astro';
import config from '@/data/site.config';
const pageTitle = 'Legal | ' + config.siteName;
const pageDescription = 'Juridische informatie voor Beste Elektrolyten.';
const pageUrl = new URL('/impressum/', config.domain).toString();
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" slot="json-ld" set:html={JSON.stringify({ '@context':'https://schema.org','@type':'BreadcrumbList', itemListElement:[{'@type':'ListItem',position:1,name:'Home',item:config.domain},{'@type':'ListItem',position:2,name:'Legal',item:pageUrl}] })} />
  <main style="background:#fff;"><div class="container-large padding-global"><div class="padding-section-medium rich-text"><h1>Legal</h1><p><strong>Beste Elektrolyten</strong> is een onafhankelijk affiliate-informatieproject van LMC.</p><h2>Contact</h2><p>E-mail: <a href="#contact">hello [at] le-meilleur-complement.fr</a></p><h2>Affiliate melding</h2><p>Sommige links op deze website zijn affiliate links. Als je via deze links koopt, kan LMC een commissie ontvangen. De prijs voor jou blijft gelijk.</p><h2>Redactionele onafhankelijkheid</h2><p>Onze vergelijkingen zijn redactionele koopgidsen. Ze vervangen geen medisch advies.</p></div></div></main>
</BaseLayout>
